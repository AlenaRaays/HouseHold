@model Orders

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Заказ оформлен — HouseHold</title>
    <link rel="stylesheet" href="~/css/mainshop.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/checkout.css" asp-append-version="true">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <header class="header">
        <div class="container">
            <div class="header-content">
                <div class="logo">
                    <i class="fas fa-microchip"></i>
                    <span>HouseHold</span>
                </div>
            </div>
        </div>
    </header>

    <main class="success-page">
        <div class="container">
            <div class="success-card">
                <div class="success-icon">
                    <i class="fas fa-check-circle"></i>
                </div>

                <h1>Заказ успешно оформлен!</h1>
                <p class="order-number">Номер заказа: <strong>@Model.order_number</strong></p>

                <div class="order-details">
                    <div class="detail-row">
                        <span>Дата заказа:</span>
                        <strong>@Model.created_date.ToString("dd.MM.yyyy HH:mm")</strong>
                    </div>
                    <div class="detail-row">
                        <span>Статус:</span>
                        <strong>@Model.status?.status_name</strong>
                    </div>
                    <div class="detail-row">
                        <span>Способ доставки:</span>
                        <strong>@Model.deliveryMethod?.name</strong>
                    </div>
                    <div class="detail-row">
                        <span>Способ оплаты:</span>
                        <strong>@Model.paymentMethod?.name</strong>
                    </div>
                    <div class="detail-row">
                        <span>Адрес доставки:</span>
                        <strong>@Model.delivery_address</strong>
                    </div>
                    <div class="detail-row total">
                        <span>Сумма заказа:</span>
                        <strong>@Model.total_amount.ToString("N0") ₽</strong>
                    </div>
                </div>

                <div class="success-actions">
                    <a href="@Url.Action("Index", "MainShop")" class="btn-primary">
                        <i class="fas fa-shopping-bag"></i> Продолжить покупки
                    </a>
                    <a href="@Url.Action("History", "Order")" class="btn-secondary">
                        <i class="fas fa-history"></i> Мои заказы
                    </a>
                </div>
            </div>
        </div>
    </main>
</body>
</html>