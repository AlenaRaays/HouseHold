@model ShopViewModel


<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HouseHold — Магазин электроники</title>
    <link rel="stylesheet" href="~/css/mainshop.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <!-- Шапка сайта -->
    <header class="header">
        <div class="container">
            <div class="header-content">
                <div class="logo">
                    <i class="fas fa-microchip"></i>
                    <span>HouseHold</span>
                </div>

                <div class="search-bar">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Поиск товаров...">
                    <button class="search-btn">Найти</button>
                </div>

                <div class="header-icons">
                    <a href="#" class="icon-btn cart">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="badge">3</span>
                    </a>
                    
                    @if (Model.UserId != null)
                    {
                        <a href="#" class="icon-btn login">
                            <i class="fas fa-user-circle"></i>
                            <span>@Model.UserName</span>
                        </a>
                    }
                    else
                    {
                        <a href="@Url.Action("Index", "Authorize")" class="icon-btn login">
                            <i class="fas fa-user-circle"></i>
                            <span>Войти</span>
                        </a>
                    }
                </div>
            </div>
        </div>
    </header>

    <!-- Навигационное меню категорий -->
    <nav class="categories-nav">
        <button id="btnLeft" class="scroll-btn left">&#10094;</button>
        <ul class="categories-list">
            <li>
                <a href="@Url.Action("Index", "MainShop")" class="active">
                    Все товары
                </a>
            </li>

            @foreach (var cat in Model.Categoryy)
            {
                <li>
                    <a href="@Url.Action("Index", "MainShop", new { categoryId = cat.category_id })">
                        @cat.name
                    </a>
                </li>
            }
        </ul>
        <button id="btnRight" class="scroll-btn right">&#10095;</button>
    </nav>

    <!-- Баннер / акция -->
    <section class="promo-banner">
        <div class="container">
            <div class="banner-content">
                <h2>Скидка до 30% на смартфоны</h2>
                <p>При покупке от двух товаров — дополнительная скидка 10%</p>
                <a href="#" class="banner-btn">Узнать больше →</a>
            </div>
        </div>
    </section>

    <!-- Основной контент: каталог товаров -->
    <main class="main-content">
        <div class="container">
            <!-- Фильтры и сортировка -->
            <div class="catalog-header">
                <h1>Каталог товаров</h1>
                <div class="sort-options">
                    <span>Сортировать:</span>
                    <select class="sort-select">
                        <option value="popular">По популярности</option>
                        <option value="price_asc">Сначала дешевле</option>
                        <option value="price_desc">Сначала дороже</option>
                        <option value="new">По новизне</option>
                    </select>
                </div>
            </div>

            <div class="catalog-layout">
                <!-- Боковой фильтр -->
                <aside class="filters-sidebar">
                    <div class="filter-section">
                        <h3><i class="fas fa-sliders-h"></i> Цена</h3>
                        @{
                            var maxPrice = Model.Productt.Max(x => x.price);
                        }

                        <input type="range"
                               min="0"
                               max="@Model.MaxPrice"
                               value="@Model.MaxPrice" />

                        <div class="price-range">
                            <div class="price-inputs">

                                <input type="number" value="0">
                                <span>—</span>
                                <input type="number" value="@Model.MaxPrice">

                            </div>
                        </div>
                    </div>

                    <div class="filter-section">
                        <h3><i class="fas fa-tag"></i> Категории</h3>

                        <ul class="category-list">

                            @foreach (var parent in Model.parentCategories)
                            {
                                <li>
                                    <label class="checkbox-label">
                                        <input type="checkbox" value="@parent.parent_category_id"> @parent.name
                                    </label>

                                    @if (parent.categories != null && parent.categories.Any())
                                    {
                                        <ul>
                                            @foreach (var child in parent.categories)
                                            {
                                                <li>
                                                    <label class="checkbox-label">
                                                        <input type="checkbox" value="@child.category_id">
                                                        @child.name
                                                    </label>
                                                </li>
                                            }
                                        </ul>
                                    }
                                </li>
                            }
                        </ul>
                    </div>

                    <button class="reset-filters">Сбросить фильтры</button>
                </aside>

                <!-- Сетка товаров -->
                <div class="products-grid">

                    @foreach (var product in Model.Productt)
                    {
                        <div class="product-card">

                            @if (product.productTags != null)
                            {
                                if (product.productTags.Any(t => t.Tag.tag_name == "Хит продаж"))
                                {
                                    <div class="product-badge hot">Хит</div>
                                }

                                if (product.productTags.Any(t => t.Tag.tag_name == "Новинка"))
                                {
                                    <div class="product-badge new">Новинка</div>
                                }
                            }

                            @if (product.discount_percent > 0)
                            {
                                <div class="product-badge sale">
                                    -@product.discount_percent%
                                </div>
                            }

                            @* ===== IMAGE ===== *@
                            <div class="product-image">
                                <i class="fas fa-box"></i>
                            </div>

                            @* ===== TITLE ===== *@
                            <h3 class="product-title">@product.name</h3>

                            @* ===== PRICE ===== *@
                            <div class="product-price">

                                <span class="current-price">
                                    @product.price ₽
                                </span>

                                @{
                                    var lastOldPrice = product.priceHistories?
                                    .OrderByDescending(p => p.Product.created_date)
                                    .FirstOrDefault()?.old_price;
                                }

                                @if (lastOldPrice != null)
                                {
                                    <span class="old-price">
                                        @lastOldPrice ₽
                                    </span>
                                }

                            </div>

                            @* ===== ADD TO CART ===== *@
                            <button class="add-to-cart">
                                <i class="fas fa-shopping-cart"></i> В корзину
                            </button>

                        </div>
                    }
                </div>
        </div>
            <!-- Пагинация -->
            <div class="pagination">
                <a href="#" class="active">1</a>
                <a href="#">2</a>
                <a href="#">3</a>
                <a href="#">4</a>
                <a href="#">→</a>
            </div>
    </main>

    <!-- Подвал -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <div class="logo">
                        <i class="fas fa-microchip"></i>
                        <span>HouseHold</span>
                    </div>
                    <p>Лучшие электронные товары по доступным ценам</p>
                </div>
                <div class="footer-section">
                    <h4>Контакты</h4>
                    <p><i class="fas fa-phone"></i> +7 (800) 555-35-35</p>
                    <p><i class="fas fa-envelope"></i> info@technomarket.ru</p>
                </div>
                <div class="footer-section">
                    <h4>Мы в соцсетях</h4>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-telegram"></i></a>
                        <a href="#"><i class="fab fa-vk"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 HouseHold. Все права защищены.</p>
            </div>
        </div>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const list = document.querySelector('.categories-list');
            const btnLeft = document.getElementById('btnLeft');
            const btnRight = document.getElementById('btnRight');

            btnLeft.addEventListener('click', () => {
                list.scrollBy({
                    left: -150,
                    behavior: 'smooth'
                });
            });

            btnRight.addEventListener('click', () => {
                list.scrollBy({
                    left: 150,
                    behavior: 'smooth'
                });
            });
        });
    </script>

</body>
</html>