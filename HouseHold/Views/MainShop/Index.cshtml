@model ShopViewModel


<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HouseHold — Магазин электроники</title>
    <link rel="stylesheet" href="~/css/mainshop.css" asp-append-version="true">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <!-- Шапка сайта -->
    <header class="header">
        <div class="container">
            <div class="header-content">
                <div class="logo">
                    <i class="fas fa-microchip"></i>
                    <span>HouseHold</span>
                </div>
                <form method="get" asp-action="Index" asp-controller="MainShop">
                    <div class="search-bar">
                    <i class="fas fa-search"></i>
                        <input 
                            type="text" 
                            placeholder="Поиск товаров..."
                            name="searchQuery"
                            value="@Model.SearchQuery">
                        <button class="search-btn" type="submit">Найти</button>
                    </div>
                </form>

                <div class="header-icons">
                    <a href="@Url.Action("Index", "Favorite")" class="icon-btn favorites">
                    <i class="fas fa-heart"></i>
                        @if (Model.UserId != null && Model.FavoriteProductIds != null)
                        {
                            <span class="badge">@Model.FavoriteProductIds.Count</span>
                        }
                    </a>

                    <a href="@Url.Action("Index","Cart")" class="icon-btn cart">
                        <i class="fas fa-shopping-cart"></i>
                        @if (Model.UserId != null && Model.CartItemsCount != null)
                        {
                            <span class="badge">@Model.CartItemsCount</span>
                        }
                    </a>
                    
                    @if (Model.UserId != null)
                    {
                        <a href="@Url.Action("Index", "Profile")" class="icon-btn login">
                            <i class="fas fa-user-circle"></i>
                            <span>@Model.UserName</span>
                        </a>
                    }
                    else
                    {
                        <a href="@Url.Action("Index", "Authorize")" class="icon-btn login">
                            <i class="fas fa-user-circle"></i>
                            <span>Войти</span>
                        </a>
                    }
                </div>
            </div>
        </div>
    </header>

    <!-- Баннер / акция -->
    <section class="promo-banner">
        <div class="container">
            <div class="banner-content">
                <h2>Скидка до 30% на пылесосы</h2>
            </div>
        </div>
    </section>

    <!-- Основной контент: каталог товаров -->
    <main class="main-content">
        <div class="container">
            <form method="get" asp-action="Index" asp-controller="MainShop" onchange="this.form.submit()">
                <div class="catalog-header">
                    <h1>Каталог товаров</h1>
                    <div class="sort-options">
                        <span>Сортировать:</span>
                            <select class="sort-select" name="sortby" onchange="this.form.submit()">
                                <option value="default">По умолчанию</option>
                                <option value="price_asc" selected="@(Model.SortBy == "price_asc")">Сначала дешевле</option>
                                <option value="price_desc" selected="@(Model.SortBy == "price_desc")">Сначала дороже</option>
                                <option value="new" selected="@(Model.SortBy == "new")">По новизне</option>
                            </select>
                    </div>
                </div>
                <div class="catalog-layout">
                    <!-- Боковой фильтр -->
                    <aside class="filters-sidebar">
                        <div class="filter-section">
                            <h3><i class="fas fa-sliders-h"></i> Цена</h3>

                            <div class="price-inputs">

                                <input type="number"
                                        name="minprice"
                                        value="@Model.MinPrice"
                                        onchange="this.form.submit()" />
                                <span>—</span>
                                <input type="number"
                                        name="maxprice"
                                        value="@Model.MaxPrice"
                                        onchange="this.form.submit()" />
                            </div>
                        </div>

                        <div class="filter-section">
                            <h3><i class="fas fa-tag"></i> Категории</h3>

                            <ul class="category-list">

                                @foreach (var parent in Model.parentCategories)
                                {
                                    <li>

                                        <label class="checkbox-label">
                                            <input type="checkbox"
                                                    name="PcategoryId"
                                                    value="@parent.parent_category_id"
                                                    onchange="this.form.submit()"
                                                    @(Model.PcategoryId.Contains(parent.parent_category_id) ? "checked" : "")/>
                                            @parent.name
                                        </label>

                                        @if (parent.categories != null && parent.categories.Any())
                                        {
                                            <ul>
                                                @foreach (var child in parent.categories)
                                                {
                                                    <li>
                                                        <label class="checkbox-label">
                                                            <input type="checkbox"
                                                                    name="categoryId"
                                                                    value="@child.category_id"
                                                                    onchange="this.form.submit()"
                                                                    @(Model.CategoryId.Contains(child.category_id) ? "checked" : "") />
                                                            @child.name
                                                        </label>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </li>
                                }
                            </ul>
                        </div>
                        <button class="reset-filters">Сбросить фильтры</button>
                    </aside>
            </form>

                    <!-- Сетка товаров -->
                    <div class="products-grid">
                        @foreach (var product in Model.Productt)
                        {
                            <div class="product-card">

                                @if (product.productTags != null)
                                {
                                    if (product.productTags.Any(t => t.Tag.tag_name == "Хит продаж"))
                                    {
                                        <div class="product-badge hot">Хит</div>
                                    }

                                    if (product.productTags.Any(t => t.Tag.tag_name == "Новинка"))
                                    {
                                        <div class="product-badge new">Новинка</div>
                                    }
                                }

                                @if (product.discount_percent > 0)
                                {
                                    <div class="product-badge sale">
                                        -@product.discount_percent%
                                    </div>
                                }

                                <div class="product-image">
                                    <i class="fas fa-box"></i>
                                </div>

                                <h3 class="product-title">@product.name</h3>

                                <div class="product-stock @(product.amount > 0 ? "in-stock" : "out-of-stock")">
                                    <i class="fas @(product.amount > 0 ? "fa-check-circle" : "fa-times-circle")"></i>
                                    @if (product.amount > 0)
                                    {
                                        <span>В наличии: @product.amount шт.</span>
                                    }
                                    else
                                    {
                                        <span>Нет в наличии</span>
                                    }
                                </div>

                                <div class="product-price">

                                    <span class="current-price">
                                        @product.price.ToString("N0") ₽
                                    </span>

                                    @{
                                        var lastOldPrice = product.priceHistories?
                                        .OrderByDescending(p => p.Product.created_date)
                                        .FirstOrDefault()?.old_price;
                                    }

                                    @if (lastOldPrice != null)
                                    {
                                        <span class="old-price">
                                            @lastOldPrice ₽
                                        </span>
                                    }

                                </div>

                                <div class="product-actions">

                                    @if (product.amount > 0)
                                    {
                                        <form asp-controller="Cart" asp-action="Add" method="post">
                                            <input type="hidden" name="productId" value="@product.product_id" />

                                            <div class="quantity-selector">
                                                <label>Кол-во:</label>
                                                <div class="quantity-input-wrapper">
                                                    <input type="number"
                                                           name="quantity"
                                                           value="1"
                                                           min="1"
                                                           max="@product.amount"
                                                           step="1"
                                                           class="quantity-input"
                                                           oninvalid="this.setCustomValidity('Введите число от 1 до @product.amount')"
                                                           oninput="this.setCustomValidity('')" />
                                                    <span class="quantity-hint">из @product.amount шт.</span>
                                                </div>
                                            </div>

                                            @if (product.amount > 0)
                                            {
                                                <div class="max-quantity-hint @(product.amount < 5 ? "low-stock" : "") @(product.amount == 0 ? "out-of-stock" : "")">
                                                    <i class="fas fa-box"></i> В наличии: @product.amount шт.
                                                </div>
                                            }

                                            <button type="submit" class="add-to-cart">
                                                <i class="fas fa-shopping-cart"></i> В корзину
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="add-to-cart disabled" disabled>
                                            <i class="fas fa-shopping-cart"></i> Нет в наличии
                                        </button>
                                    }

                                    @if (Model.UserId != null)
                                    {
                                        <form asp-controller="Favorite" asp-action="Add" method="post">
                                            <input type="hidden" name="productId" value="@product.product_id" />
                                            <input type="hidden" name="returnUrl" value="@Url.Action("Index", "MainShop", new { categoryId = Context.Request.Query["categoryId"], minprice = Context.Request.Query["minprice"], maxprice = Context.Request.Query["maxprice"], sortby = Context.Request.Query["sortby"] })" />

                                            @if (Model.FavoriteProductIds != null && Model.FavoriteProductIds.Contains(product.product_id))
                                            {
                                                <button type="submit" class="favorite-btn active" formaction="@Url.Action("Remove", "Favorite")">
                                                    <i class="fas fa-heart"></i> В избранном
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="favorite-btn">
                                                    <i class="far fa-heart"></i> В избранное
                                                </button>
                                            }
                                        </form>
                                    }
                                    else
                                    {
                                        <a href="@Url.Action("Index", "Authorize")" class="favorite-btn">
                                            <i class="far fa-heart"></i> В избранное
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
        </div>
    </main>

    <!-- Подвал -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <div class="logo">
                        <i class="fas fa-microchip"></i>
                        <span>HouseHold</span>
                    </div>
                    <p>Лучшие электронные товары по доступным ценам</p>
                </div>
                <div class="footer-section">
                    <h4>Контакты</h4>
                    <p><i class="fas fa-phone"></i> +7 (800) 555-35-35</p>
                    <p><i class="fas fa-envelope"></i> info@technomarket.ru</p>
                </div>
                <div class="footer-section">
                    <h4>Мы в соцсетях</h4>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-telegram"></i></a>
                        <a href="#"><i class="fab fa-vk"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 HouseHold. Все права защищены.</p>
            </div>
        </div>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const list = document.querySelector('.categories-list');
            const btnLeft = document.getElementById('btnLeft');
            const btnRight = document.getElementById('btnRight');

            btnLeft.addEventListener('click', () => {
                list.scrollBy({
                    left: -150,
                    behavior: 'smooth'
                });
            });

            btnRight.addEventListener('click', () => {
                list.scrollBy({
                    left: 150,
                    behavior: 'smooth'
                });
            });
        });
    </script>

</body>
</html>