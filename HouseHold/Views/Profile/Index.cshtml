@model Users

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Профиль — HouseHold</title>
    <link rel="stylesheet" href="~/css/mainshop.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <!-- Шапка сайта -->
    <header class="header">
        <div class="container">
            <div class="header-content">
                <div class="logo">
                    <i class="fas fa-microchip"></i>
                    <span>HouseHold</span>
                </div>

                <div class="search-bar">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Поиск товаров...">
                    <button class="search-btn">Найти</button>
                </div>

                <div class="header-icons">
                    <a href="@Url.Action("Index", "Favorite")" class="icon-btn favorites">
                        <i class="fas fa-heart"></i>
                    </a>

                    <a href="@Url.Action("Index", "Cart")" class="icon-btn cart">
                        <i class="fas fa-shopping-cart"></i>
                    </a>

                    <a href="@Url.Action("Index", "Profile")" class="icon-btn login">
                        <i class="fas fa-user-circle"></i>
                        <span>@Model.first_name</span>
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- Основной контент -->
    <main class="profile-page">
        <div class="container">
            <!-- Хлебные крошки -->
            <div class="breadcrumbs">
                <a href="@Url.Action("Index", "MainShop")">Главная</a>
                <i class="fas fa-chevron-right"></i>
                <span>Профиль</span>
            </div>

            <!-- Сообщения -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
                </div>
            }

            <div class="profile-container">
                <div class="profile-card">
                    <div class="profile-header">
                        <i class="fas fa-user-circle avatar-icon"></i>
                        <h2>@Model.first_name @Model.last_name</h2>
                        <p>ID: @Model.user_id</p>
                        <p>
                            Роль:
                            <span class="badge @GetRoleBadgeClass(Model.UserRole?.role_name)">
                                @(Model.UserRole?.role_name ?? "Клиент")
                            </span>
                        </p>
                        <p>
                            Статус:
                            <span class="badge @(Model.is_active == true ? "bg-success" : "bg-danger")">
                                @(Model.is_active == true ? "Активен" : "Заблокирован")
                            </span>
                        </p>
                    </div>

                    <div class="profile-info">
                        <div class="info-item">
                            <span>Фамилия:</span>
                            <strong>@Model.last_name</strong>
                        </div>

                        <div class="info-item">
                            <span>Имя:</span>
                            <strong>@Model.first_name</strong>
                        </div>

                        <div class="info-item">
                            <span>Email:</span>
                            <strong>@Model.email</strong>
                        </div>

                        <div class="info-item">
                            <span>Телефон:</span>
                            <strong>@Model.phone</strong>
                        </div>

                        <div class="info-item">
                            <span>Дата регистрации:</span>
                            <strong>@(Model.registration_date.ToString("dd.MM.yyyy") ?? "—")</strong>
                        </div>

                        @if (Model.discount > 0)
                        {
                            <div class="info-item highlight">
                                <span>Персональная скидка:</span>
                                <strong>@Model.discount%</strong>
                            </div>
                        }
                    </div>

                    <div class="profile-actions">
                        <a href="@Url.Action("Edit", "Profile")" class="btn btn-edit">
                            <i class="fas fa-edit"></i> Редактировать
                        </a>

                        <a href="@Url.Action("ChangePassword", "Profile")" class="btn btn-password">
                            <i class="fas fa-key"></i> Сменить пароль
                        </a>

                        <a href="@Url.Action("Index", "MainShop")" class="btn btn-back">
                            <i class="fas fa-arrow-left"></i> На главную
                        </a>

                        <a href="@Url.Action("Logout", "Profile")" class="btn btn-logout">
                            <i class="fas fa-sign-out-alt"></i> Выйти
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Подвал -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <div class="logo">
                        <i class="fas fa-microchip"></i>
                        <span>HouseHold</span>
                    </div>
                    <p>Лучшие электронные товары по доступным ценам</p>
                </div>
                <div class="footer-section">
                    <h4>Контакты</h4>
                    <p><i class="fas fa-phone"></i> +7 (800) 555-35-35</p>
                    <p><i class="fas fa-envelope"></i> info@household.ru</p>
                </div>
                <div class="footer-section">
                    <h4>Мы в соцсетях</h4>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-telegram"></i></a>
                        <a href="#"><i class="fab fa-vk"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 HouseHold. Все права защищены.</p>
            </div>
        </div>
    </footer>

    @functions {
        private string GetRoleBadgeClass(string role)
        {
            return role switch
            {
                "Administrator" => "bg-danger",
                "Manager" => "bg-warning",
                "AdminSite" => "bg-info",
                "Client" => "bg-success",
                _ => "bg-secondary"
            };
        }
    }
</body>
</html>