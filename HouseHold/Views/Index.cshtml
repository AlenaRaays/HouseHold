@{
<!DOCTYPE html>
<html lang="ru">
    <head>
        <meta charset="UTF-8">
        <title>Авторизация</title>
        <link rel="stylesheet" href="~/css/authorize.css">
    </head>
    <body>
        <div class="login-container">
            <form id="loginform" class="login-form" method="post" asp-action="Index" asp-controller="Authorize">
                <h2>Вход</h2>

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
                {
                    <div class="alert alert-danger">
                        @foreach (var error in ViewData.ModelState[string.Empty].Errors)
                        {
                            <p>@error.ErrorMessage</p>
                        }
                    </div>
                }

                <div class="input-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="Email" required>
                </div>

                <div class="input-group">
                    <label for="password">Пароль</label>
                    <input type="password" id="password" name="Password" required>
                </div>

                <div class="checkbox-group">
                    <input type="checkbox" id="rememberMe" name="RememberMe">
                    <label for="rememberMe">Запомнить меня</label>
                </div>

                <button type="submit" class="login-btn">Войти</button>

                <p class="footer-text">
                    Нет аккаунта? <a href="@Url.Action("Index", "Registration")">Регистрация</a>
                </p>
            </form>
        </div>
        @section Scripts {
            @{
                await Html.RenderPartialAsync("_ValidationScriptsPartial");
            }
        }
    </body>
</html>
}
