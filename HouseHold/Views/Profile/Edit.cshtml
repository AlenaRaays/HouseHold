@model HouseHold.Models.ViewModels.EditProfileViewModel

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Редактирование профиля — HouseHold</title>
    <link rel="stylesheet" href="~/css/mainshop.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <!-- Шапка сайта -->
    <header class="header">
        <div class="container">
            <div class="header-content">
                <div class="logo">
                    <i class="fas fa-microchip"></i>
                    <span>HouseHold</span>
                </div>

                <div class="search-bar">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Поиск товаров...">
                    <button class="search-btn">Найти</button>
                </div>

                <div class="header-icons">
                    <a href="@Url.Action("Index", "Favorite")" class="icon-btn favorites">
                        <i class="fas fa-heart"></i>
                    </a>

                    <a href="@Url.Action("Index", "Cart")" class="icon-btn cart">
                        <i class="fas fa-shopping-cart"></i>
                    </a>

                    <a href="@Url.Action("Index", "Profile")" class="icon-btn login">
                        <i class="fas fa-user-circle"></i>
                        <span>Профиль</span>
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- Основной контент -->
    <main class="profile-page">
        <div class="container">
            <!-- Хлебные крошки -->
            <div class="breadcrumbs">
                <a href="@Url.Action("Index", "MainShop")">Главная</a>
                <i class="fas fa-chevron-right"></i>
                <a href="@Url.Action("Index", "Profile")">Профиль</a>
                <i class="fas fa-chevron-right"></i>
                <span>Редактирование</span>
            </div>

            <div class="profile-container">
                <div class="profile-card">
                    <div class="profile-header">
                        <i class="fas fa-user-edit avatar-icon"></i>
                        <h2>Редактирование профиля</h2>
                        <p>
                            <span class="badge @GetRoleBadgeClass(Model.RoleName)">@(Model.RoleName ?? "Клиент")</span>
                            <span class="badge @(Model.Status == true ? "bg-success" : "bg-danger")">
                                @(Model.Status == true ? "Активен" : "Заблокирован")
                            </span>
                        </p>
                        <p class="text-muted">
                            <i class="fas fa-info-circle"></i> Роль и статус изменить нельзя
                        </p>
                    </div>

                    <div class="profile-info">
                        <form asp-action="Edit" method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="UserId" />

                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <div class="form-group">
                                <label asp-for="LastName">Фамилия <span class="text-danger">*</span></label>
                                <input asp-for="LastName" class="form-control" placeholder="Иванов" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="FirstName">Имя <span class="text-danger">*</span></label>
                                <input asp-for="FirstName" class="form-control" placeholder="Иван" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Email">Email <span class="text-danger">*</span></label>
                                <input asp-for="Email" class="form-control" type="email" placeholder="example@mail.ru" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Phone">Телефон <span class="text-danger">*</span></label>
                                <input asp-for="Phone" class="form-control" placeholder="+79001234567" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>

                            <div class="form-group disabled-field">
                                <label>Роль</label>
                                <input type="text" class="form-control" value="@Model.RoleName" disabled />
                                <small class="text-muted">Роль может изменить только администратор</small>
                            </div>

                            <div class="form-group disabled-field">
                                <label>Статус</label>
                                <input type="text" class="form-control" value="@(Model.Status == true ? "Активен" : "Заблокирован")" disabled />
                                <small class="text-muted">Статус может изменить только администратор</small>
                            </div>

                            <div class="form-group disabled-field">
                                <label>Персональная скидка</label>
                                <input type="text" class="form-control" value="@Model.PersonalDiscount%" disabled />
                                <small class="text-muted">Скидка устанавливается менеджером</small>
                            </div>

                            <hr />

                            <div class="profile-actions">
                                <button type="submit" class="btn btn-save">
                                    <i class="fas fa-save"></i> Сохранить
                                </button>

                                <a href="@Url.Action("Index", "Profile")" class="btn btn-cancel">
                                    <i class="fas fa-times"></i> Отмена
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Подвал -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <div class="logo">
                        <i class="fas fa-microchip"></i>
                        <span>HouseHold</span>
                    </div>
                    <p>Лучшие электронные товары по доступным ценам</p>
                </div>
                <div class="footer-section">
                    <h4>Контакты</h4>
                    <p><i class="fas fa-phone"></i> +7 (800) 555-35-35</p>
                    <p><i class="fas fa-envelope"></i> info@household.ru</p>
                </div>
                <div class="footer-section">
                    <h4>Мы в соцсетях</h4>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-telegram"></i></a>
                        <a href="#"><i class="fab fa-vk"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 HouseHold. Все права защищены.</p>
            </div>
        </div>
    </footer>

    @functions {
        private string GetRoleBadgeClass(string role)
        {
            return role switch
            {
                "Administrator" => "bg-danger",
                "Manager" => "bg-warning",
                "AdminSite" => "bg-info",
                "Client" => "bg-success",
                _ => "bg-secondary"
            };
        }
    }

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>