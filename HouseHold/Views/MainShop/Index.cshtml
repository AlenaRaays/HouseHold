@model ShopViewModel

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HouseHold — Магазин электроники</title>
    <link rel="stylesheet" href="~/css/mainshop.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <!-- Шапка сайта -->
    <header class="header">
        <div class="container">
            <div class="header-content">
                <div class="logo">
                    <i class="fas fa-microchip"></i>
                    <span>HouseHold</span>
                </div>

                <div class="search-bar">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Поиск товаров...">
                    <button class="search-btn">Найти</button>
                </div>

                <div class="header-icons">
                    <a href="#" class="icon-btn cart">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="badge">3</span>
                    </a>
                    
                        <a href="@Url.Action("Index", "Authorize")" class="icon-btn login">
                            <i class="fas fa-user-circle"></i>
                            <span>Войти</span>
                        </a>
                </div>
            </div>
        </div>
    </header>

    <!-- Навигационное меню категорий -->
    <nav class="categories-nav">
        <div class="container">
            <ul class="categories-list">
                <li><a href="#" class="active">Все товары</a></li>
                @foreach (var i in Model.Categoryy)
                {
                    <li><a href="#">@i.name</a></li>
                }
            </ul>
        </div>
    </nav>

    <!-- Баннер / акция -->
    <section class="promo-banner">
        <div class="container">
            <div class="banner-content">
                <h2>Скидка до 30% на смартфоны</h2>
                <p>При покупке от двух товаров — дополнительная скидка 10%</p>
                <a href="#" class="banner-btn">Узнать больше →</a>
            </div>
        </div>
    </section>

    <!-- Основной контент: каталог товаров -->
    <main class="main-content">
        <div class="container">
            <!-- Фильтры и сортировка -->
            <div class="catalog-header">
                <h1>Каталог товаров</h1>
                <div class="sort-options">
                    <span>Сортировать:</span>
                    <select class="sort-select">
                        <option>По популярности</option>
                        <option>Сначала дешевле</option>
                        <option>Сначала дороже</option>
                        <option>По новизне</option>
                    </select>
                </div>
            </div>

            <div class="catalog-layout">
                <!-- Боковой фильтр -->
                <aside class="filters-sidebar">
                    <div class="filter-section">
                        <h3><i class="fas fa-sliders-h"></i> Цена</h3>
                        <div class="price-range">
                            <input type="range" min="0" max="200000" value="50000">
                            <div class="price-inputs">
                                <input type="number" placeholder="от" value="0">
                                <span>—</span>
                                <input type="number" placeholder="до" value="50000">
                            </div>
                        </div>
                    </div>

                    <div class="filter-section">
                        <h3><i class="fas fa-tag"></i> Категории</h3>
                        <label class="checkbox-label">
                            <input type="checkbox"> Смартфоны
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox"> Ноутбуки
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox"> Планшеты
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox"> Наушники
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox"> Умные часы
                        </label>
                    </div>

                    <div class="filter-section">
                        <h3><i class="fas fa-star"></i> Рейтинг</h3>
                        <label class="checkbox-label">
                            <input type="checkbox"> 5 ★ и выше
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox"> 4 ★ и выше
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox"> 3 ★ и выше
                        </label>
                    </div>

                    <button class="reset-filters">Сбросить фильтры</button>
                </aside>

                <!-- Сетка товаров -->
                <div class="products-grid">
                    <!-- Товар 1 -->
                    <div class="product-card">
                        <div class="product-badge hot">Хит</div>
                        <div class="product-image">
                            <i class="fas fa-mobile-alt"></i>
                        </div>
                        <h3 class="product-title">iPhone 15 Pro</h3>
                        <div class="product-rating">
                            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
                            <span>4.8</span>
                        </div>
                        <div class="product-price">
                            <span class="current-price">89 990 ₽</span>
                            <span class="old-price">99 990 ₽</span>
                        </div>
                        <button class="add-to-cart">
                            <i class="fas fa-shopping-cart"></i> В корзину
                        </button>
                    </div>

                    <!-- Товар 2 -->
                    <div class="product-card">
                        <div class="product-badge new">Новинка</div>
                        <div class="product-image">
                            <i class="fas fa-laptop"></i>
                        </div>
                        <h3 class="product-title">MacBook Air M3</h3>
                        <div class="product-rating">
                            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                            <span>5.0</span>
                        </div>
                        <div class="product-price">
                            <span class="current-price">129 990 ₽</span>
                            <span class="old-price">149 990 ₽</span>
                        </div>
                        <button class="add-to-cart">
                            <i class="fas fa-shopping-cart"></i> В корзину
                        </button>
                    </div>

                    <!-- Товар 3 -->
                    <div class="product-card">
                        <div class="product-image">
                            <i class="fas fa-headphones"></i>
                        </div>
                        <h3 class="product-title">Sony WH-1000XM5</h3>
                        <div class="product-rating">
                            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                            <span>5.0</span>
                        </div>
                        <div class="product-price">
                            <span class="current-price">32 990 ₽</span>
                        </div>
                        <button class="add-to-cart">
                            <i class="fas fa-shopping-cart"></i> В корзину
                        </button>
                    </div>

                    <!-- Товар 4 -->
                    <div class="product-card">
                        <div class="product-badge sale">-20%</div>
                        <div class="product-image">
                            <i class="fas fa-tablet-alt"></i>
                        </div>
                        <h3 class="product-title">iPad Air 5</h3>
                        <div class="product-rating">
                            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                            <span>4.9</span>
                        </div>
                        <div class="product-price">
                            <span class="current-price">59 990 ₽</span>
                            <span class="old-price">74 990 ₽</span>
                        </div>
                        <button class="add-to-cart">
                            <i class="fas fa-shopping-cart"></i> В корзину
                        </button>
                    </div>

                    <!-- Товар 5 -->
                    <div class="product-card">
                        <div class="product-image">
                            <i class="fas fa-clock"></i>
                        </div>
                        <h3 class="product-title">Apple Watch Series 9</h3>
                        <div class="product-rating">
                            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
                            <span>4.7</span>
                        </div>
                        <div class="product-price">
                            <span class="current-price">41 990 ₽</span>
                        </div>
                        <button class="add-to-cart">
                            <i class="fas fa-shopping-cart"></i> В корзину
                        </button>
                    </div>

                    <!-- Товар 6 -->
                    <div class="product-card">
                        <div class="product-badge hot">Хит</div>
                        <div class="product-image">
                            <i class="fas fa-gamepad"></i>
                        </div>
                        <h3 class="product-title">PlayStation 5</h3>
                        <div class="product-rating">
                            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                            <span>4.9</span>
                        </div>
                        <div class="product-price">
                            <span class="current-price">62 990 ₽</span>
                        </div>
                        <button class="add-to-cart">
                            <i class="fas fa-shopping-cart"></i> В корзину
                        </button>
                    </div>

                    <!-- Товар 7 -->
                    <div class="product-card">
                        <div class="product-image">
                            <i class="fas fa-keyboard"></i>
                        </div>
                        <h3 class="product-title">Механическая клавиатура</h3>
                        <div class="product-rating">
                            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                            <span>4.9</span>
                        </div>
                        <div class="product-price">
                            <span class="current-price">12 990 ₽</span>
                        </div>
                        <button class="add-to-cart">
                            <i class="fas fa-shopping-cart"></i> В корзину
                        </button>
                    </div>

                    <!-- Товар 8 -->
                    <div class="product-card">
                        <div class="product-badge new">Новинка</div>
                        <div class="product-image">
                            <i class="fas fa-microphone"></i>
                        </div>
                        <h3 class="product-title">Микрофон Yeti X</h3>
                        <div class="product-rating">
                            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
                            <span>4.8</span>
                        </div>
                        <div class="product-price">
                            <span class="current-price">18 990 ₽</span>
                        </div>
                        <button class="add-to-cart">
                            <i class="fas fa-shopping-cart"></i> В корзину
                        </button>
                    </div>
                </div>
            </div>

            <!-- Пагинация -->
            <div class="pagination">
                <a href="#" class="active">1</a>
                <a href="#">2</a>
                <a href="#">3</a>
                <a href="#">4</a>
                <a href="#">→</a>
            </div>
        </div>
    </main>

    <!-- Подвал -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <div class="logo">
                        <i class="fas fa-microchip"></i>
                        <span>HouseHold</span>
                    </div>
                    <p>Лучшие электронные товары по доступным ценам</p>
                </div>
                <div class="footer-section">
                    <h4>Контакты</h4>
                    <p><i class="fas fa-phone"></i> +7 (800) 555-35-35</p>
                    <p><i class="fas fa-envelope"></i> info@technomarket.ru</p>
                </div>
                <div class="footer-section">
                    <h4>Мы в соцсетях</h4>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-telegram"></i></a>
                        <a href="#"><i class="fab fa-vk"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 HouseHold. Все права защищены.</p>
            </div>
        </div>
    </footer>
</body>
</html>